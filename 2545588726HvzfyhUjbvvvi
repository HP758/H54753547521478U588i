local function getLocalPlayer()
	local ok, plr = pcall(function()
		return Players.LocalPlayer
	end)
	if ok then return plr end
	return nil
end

local function getParentGui()
	local lp = getLocalPlayer()
	if lp then
		local pg = lp:FindFirstChildOfClass("PlayerGui")
		if pg then return pg end
	end
	if typeof(gethui) == "function" then
		local ok, gui = pcall(gethui)
		if ok and gui then return gui end
	end
	return game:FindFirstChildOfClass("CoreGui")
end

local function resolveAsset(value)
	if value == nil then return nil end
	if typeof(value) == "number" then
		return "rbxassetid://" .. tostring(value)
	end
	if typeof(value) == "string" then
		if value == "" then return nil end
		if value:match("^rbxassetid://") then return value end
		if value:match("^%d+$") then return "rbxassetid://" .. value end
		return value
	end
	return tostring(value)
end

local function safeCall(fn, ...)
	if typeof(fn) ~= "function" then return false, nil end
	local ok, result = pcall(fn, ...)
	if not ok and WindUI.Config.Debug then
		warn("[WindUI]", result)
	end
	return ok, result
end

local function create(className, props, parent)
	local inst = Instance.new(className)
	if props then
		for k, v in pairs(props) do
			if k ~= "Parent" then
				inst[k] = v
			end
		end
	end
	if parent then inst.Parent = parent end
	return inst
end

local function addCorner(parent, radius)
	return create("UICorner", { CornerRadius = UDim.new(0, radius or 12), Parent = parent })
end

local function addStroke(parent, color, transparency, thickness)
	return create("UIStroke", {
		Color = color or Color3.fromRGB(255, 255, 255),
		Transparency = transparency or 0.8,
		Thickness = thickness or 1,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
		Parent = parent,
	})
end

local function tween(obj, time, props, style, direction)
	local ti = TweenInfo.new(time or 0.2, style or Enum.EasingStyle.Quint, direction or Enum.EasingDirection.Out)
	local tw = TweenService:Create(obj, ti, props)
	tw:Play()
	return tw
end

WindUI.Logger = { Level = 2 }
do
	local names = { [0] = "DEBUG", [1] = "INFO", [2] = "SUCCESS", [3] = "WARN", [4] = "ERROR", [5] = "FATAL" }
	function WindUI.Logger:SetLevel(level) self.Level = tonumber(level) or self.Level end
	function WindUI.Logger:Write(level, ...)
		if level < (self.Level or 2) then return end
		local parts = {}
		for i = 1, select('#', ...) do parts[#parts+1] = tostring(select(i, ...)) end
		warn(('[WindUI][%s] %s'):format(names[level] or 'INFO', table.concat(parts, ' ')))
	end
	function WindUI.Logger:Debug(...) self:Write(0, ...) end
	function WindUI.Logger:Info(...) self:Write(1, ...) end
	function WindUI.Logger:Success(...) self:Write(2, ...) end
	function WindUI.Logger:Warn(...) self:Write(3, ...) end
	function WindUI.Logger:Error(...) self:Write(4, ...) end
	function WindUI.Logger:Fatal(...) self:Write(5, ...) end
end

WindUI.EventBus = { _channels = {} }
function WindUI.EventBus:Connect(eventName, callback)
	if typeof(callback) ~= "function" then return { Disconnect = function() end } end
	self._channels[eventName] = self._channels[eventName] or {}
	local id = HttpService:GenerateGUID(false)
	self._channels[eventName][id] = callback
	local alive = true
	return {
		Disconnect = function()
			if not alive then return end
			alive = false
			if self._channels[eventName] then self._channels[eventName][id] = nil end
		end,
	}
end
function WindUI.EventBus:Once(eventName, callback)
	local conn
	conn = self:Connect(eventName, function(...)
		if conn then conn:Disconnect() end
		callback(...)
	end)
	return conn
end
function WindUI.EventBus:Fire(eventName, ...)
	local channels = self._channels[eventName]
	if not channels then return end
	local args = table.pack(...)
	for _, cb in pairs(channels) do
		task.spawn(function()
			safeCall(cb, table.unpack(args, 1, args.n))
		end)
	end
end

local Disposable = {}; Disposable.__index = Disposable
function Disposable.new()
	return setmetatable({ _items = {}, _closed = false }, Disposable)
end
function Disposable:Add(item)
	if self._closed then
		if typeof(item) == "RBXScriptConnection" then pcall(function() item:Disconnect() end)
		elseif typeof(item) == "Instance" then pcall(function() item:Destroy() end)
		elseif type(item) == "table" and item.Destroy then pcall(function() item:Destroy() end)
		elseif type(item) == "table" and item.Cancel then pcall(function() item:Cancel() end) end
		return item
	end
	table.insert(self._items, item)
	return item
end
function Disposable:Destroy()
	if self._closed then return end
	self._closed = true
	for i = #self._items, 1, -1 do
		local item = self._items[i]
		self._items[i] = nil
		if typeof(item) == "RBXScriptConnection" then pcall(function() item:Disconnect() end)
		elseif typeof(item) == "Instance" then pcall(function() item:Destroy() end)
		elseif type(item) == "table" and item.Destroy then pcall(function() item:Destroy() end)
		elseif type(item) == "table" and item.Cancel then pcall(function() item:Cancel() end) end
	end
end
WindUI.Disposable = Disposable

WindUI.RequestManager = { _cache = {}, _retry = 1 }
local function getRequestFn()
	return request or http_request or (syn and syn.request) or (http and http.request)
end
function WindUI.RequestManager:SetRetry(count) self._retry = math.max(0, tonumber(count) or self._retry) end
function WindUI.RequestManager:_rawSend(options)
	local req = getRequestFn()
	if req then return req(options) end
	if options.Method == "GET" then
		return { Success = true, StatusCode = 200, Body = HttpService:GetAsync(options.Url) }
	elseif options.Method == "POST" then
		return { Success = true, StatusCode = 200, Body = HttpService:PostAsync(options.Url, options.Body or "", Enum.HttpContentType.ApplicationJson) }
	end
	error("No request function available")
end
function WindUI.RequestManager:Send(options)
	options = options or {}
	options.Method = options.Method or "GET"
	local retry = tonumber(options.Retry) or self._retry
	local cacheKey = options.CacheKey and tostring(options.CacheKey) or nil
	if cacheKey and self._cache[cacheKey] then return true, self._cache[cacheKey] end
	local lastErr
	for attempt = 0, retry do
		local ok, result = pcall(function() return self:_rawSend(options) end)
		if ok and result then
			if cacheKey then self._cache[cacheKey] = result end
			return true, result
		end
		lastErr = result
		task.wait(0.15 * (attempt + 1))
	end
	return false, lastErr
end
function WindUI.RequestManager:Get(url, opts)
	opts = opts or {}; opts.Url = url; opts.Method = "GET"; return self:Send(opts)
end
function WindUI.RequestManager:Post(url, body, opts)
	opts = opts or {}; opts.Url = url; opts.Method = "POST"; opts.Body = typeof(body) == "table" and HttpService:JSONEncode(body) or tostring(body or ""); opts.Headers = opts.Headers or { ["Content-Type"] = "application/json" }; return self:Send(opts)
end

WindUI.ResourceManager = { _images = {}, _ref = {} }
function WindUI.ResourceManager:AcquireImage(value)
	local key = tostring(value)
	self._ref[key] = (self._ref[key] or 0) + 1
	self._images[key] = resolveAsset(value)
	return self._images[key]
end
function WindUI.ResourceManager:ReleaseImage(value)
	local key = tostring(value)
	if self._ref[key] then
		self._ref[key] -= 1
		if self._ref[key] <= 0 then self._ref[key] = nil; self._images[key] = nil end
	end
end
function WindUI.ResourceManager:GetImage(value)
	local key = tostring(value)
	if self._images[key] then return self._images[key] end
	return self:AcquireImage(value)
end
function WindUI.ResourceManager:Clear() table.clear(self._images); table.clear(self._ref) end

