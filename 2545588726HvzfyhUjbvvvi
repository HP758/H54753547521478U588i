        corner(Indicator, 2)

        local Page = SafeCreate("ScrollingFrame", {Name="Page_"..tabName,
            Size=UDim2.new(1,0,1,-42), Position=UDim2.new(0,0,0,42),
            BackgroundTransparency=1, BorderSizePixel=0, ScrollBarThickness=3,
            ScrollBarImageColor3=C("Border"), CanvasSize=UDim2.new(0,0,0,0),
            AutomaticCanvasSize=Enum.AutomaticSize.Y, Visible=false,
            ZIndex=3, Parent=Content})
        SafeCreate("UIListLayout", {SortOrder=Enum.SortOrder.LayoutOrder,
            Padding=UDim.new(0,8), Parent=Page})
        padding(Page, 4, 16, 8, 16)

        local Tab = {Page=Page, Button=TabButton, Name=tabName,
                     Icon=Icon, Label=Label, Indicator=Indicator}

        local function selectTab()
            for _, t in ipairs(Window.Tabs) do
                t.Page.Visible = false
                SafeTween(t.Button, 0.15, {BackgroundTransparency=1})
                SafeTween(t.Icon, 0.15, {TextColor3=C("SubText")})
                SafeTween(t.Label, 0.15, {TextColor3=C("SubText")})
                SafeTween(t.Indicator, 0.15, {BackgroundTransparency=1})
            end
            Page.Visible = true
            SafeTween(TabButton, 0.15, {BackgroundTransparency=0, BackgroundColor3=C("SidebarActive")})
            SafeTween(Icon, 0.15, {TextColor3=C("Accent")})
            SafeTween(Label, 0.15, {TextColor3=C("Text")})
            SafeTween(Indicator, 0.15, {BackgroundTransparency=0})
            ContentTitle.Text = tabName
            Window.CurrentTab = Tab
        end
        Tab.Select = selectTab

        Signals:Connect(TabButton.MouseEnter, function()
            if Window.CurrentTab ~= Tab then
                SafeTween(TabButton, 0.15, {BackgroundTransparency=0.5, BackgroundColor3=C("SidebarHover")})
            end
        end)
        Signals:Connect(TabButton.MouseLeave, function()
            if Window.CurrentTab ~= Tab then
                SafeTween(TabButton, 0.15, {BackgroundTransparency=1})
            end
        end)
        Signals:Connect(TabButton.MouseButton1Click, selectTab)
        table.insert(Window.Tabs, Tab)
        if #Window.Tabs == 1 then selectTab() end

        -- ===== 组件 =====
        function Tab:AddLabel(text)
            local card = SafeCreate("Frame", {Size=UDim2.new(1,0,0,28),
                BackgroundTransparency=1, Parent=Page})
            local lbl = SafeCreate("TextLabel", {Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1, Text=text, TextColor3=C("Text"),
                Font=GetFont("bold"), TextSize=13,
                TextXAlignment=Enum.TextXAlignment.Left, Parent=card})
            return {Set=function(_,t) lbl.Text=t end, Frame=card}
        end

        function Tab:AddSection(text)
            local sec = SafeCreate("Frame", {Size=UDim2.new(1,0,0,22),
                BackgroundTransparency=1, Parent=Page})
            SafeCreate("TextLabel", {Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1, Text="-- "..text.." --",
                TextColor3=C("SubText"), Font=GetFont("bold"), TextSize=11,
                TextXAlignment=Enum.TextXAlignment.Left, Parent=sec})
            return sec
        end

        function Tab:AddButton(cfg)
            cfg = type(cfg)=="string" and {Title=cfg} or (cfg or {})
            local text = cfg.Title or cfg.Text or "Button"
            local cb = cfg.Callback or function() end
            local btn = SafeCreate("TextButton", {Size=UDim2.new(1,0,0,38),
                BackgroundColor3=C("Card"), BackgroundTransparency=0.1,
                Text=text, TextColor3=C("Text"), Font=GetFont("semibold"),
                TextSize=13, BorderSizePixel=0, AutoButtonColor=false, Parent=Page})
            btn:SetAttribute("Title", text); btn:SetAttribute("Searchable", true)
            corner(btn, 8); stroke(btn, C("Border"), 1, 0.5)
            Signals:Connect(btn.MouseEnter, function()
                SafeTween(btn, 0.15, {BackgroundColor3=C("CardHover"), BackgroundTransparency=0}) end)
            Signals:Connect(btn.MouseLeave, function()
                SafeTween(btn, 0.15, {BackgroundColor3=C("Card"), BackgroundTransparency=0.1}) end)
            Signals:Connect(btn.MouseButton1Click, function()
                SafeTween(btn, 0.08, {BackgroundColor3=C("AccentDim")})
                task.wait(0.1)
                SafeTween(btn, 0.15, {BackgroundColor3=C("Card")})
                SafeCallback(cb)
            end)
            return btn
        end

        function Tab:AddToggle(cfg)
            cfg = cfg or {}
            local title = cfg.Title or "Toggle"
            local desc = cfg.Desc or ""
            local state = cfg.Default or false
            local cb = cfg.Callback or function() end
            local flag = cfg.Flag
            if flag and Config:Get(flag) ~= nil then state = Config:Get(flag) end

            local card = SafeCreate("Frame", {Size=UDim2.new(1,0,0, desc~="" and 58 or 42),
                BackgroundColor3=C("Card"), BackgroundTransparency=0.1,
                BorderSizePixel=0, Parent=Page})
            card:SetAttribute("Title", title); card:SetAttribute("Searchable", true)
            corner(card, 8); stroke(card, C("Border"), 1, 0.5)
            SafeCreate("TextLabel", {Size=UDim2.new(1,-70,0,20),
                Position=UDim2.new(0,14,0, desc~="" and 10 or 11),
                BackgroundTransparency=1, Text=title, TextColor3=C("Text"),
                Font=GetFont("semibold"), TextSize=13,
                TextXAlignment=Enum.TextXAlignment.Left, Parent=card})
            if desc ~= "" then
                SafeCreate("TextLabel", {Size=UDim2.new(1,-70,0,16),
                    Position=UDim2.new(0,14,0,30), BackgroundTransparency=1,
                    Text=desc, TextColor3=C("SubText"), Font=GetFont("normal"),
                    TextSize=11, TextXAlignment=Enum.TextXAlignment.Left, Parent=card})
            end
            local sw = SafeCreate("Frame", {Size=UDim2.new(0,38,0,20),
                Position=UDim2.new(1,-50,0.5,-10),
                BackgroundColor3=state and C("Accent") or C("Toggle_Off"),
                BorderSizePixel=0, Parent=card})
            corner(sw, 10)
            local knob = SafeCreate("Frame", {Size=UDim2.new(0,16,0,16),
                Position=state and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8),
                BackgroundColor3=Color3.fromRGB(255,255,255), BorderSizePixel=0, Parent=sw})
            corner(knob, 8)
            local clk = SafeCreate("TextButton", {Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1, Text="", Parent=card})

            local function setState(v)
                state = v
                SafeTween(sw, 0.2, {BackgroundColor3=state and C("Accent") or C("Toggle_Off")})
                SafeTween(knob, 0.2, {Position=state and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)})
                if flag then Config:Set(flag, state) end
                SafeCallback(cb, state)
            end
            Signals:Connect(clk.MouseButton1Click, function() setState(not state) end)
            Signals:Connect(card.MouseEnter, function()
                SafeTween(card, 0.15, {BackgroundColor3=C("CardHover"), BackgroundTransparency=0}) end)
            Signals:Connect(card.MouseLeave, function()
                SafeTween(card, 0.15, {BackgroundColor3=C("Card"), BackgroundTransparency=0.1}) end)
            if state then SafeCallback(cb, true) end
            return {Set=function(_,v) setState(v) end, Get=function() return state end}
        end

        function Tab:AddSlider(cfg)
            cfg = cfg or {}
            local title = cfg.Title or "Slider"
            local min, max = cfg.Min or 0, cfg.Max or 100
            local value = cfg.Default or min
            local cb = cfg.Callback or function() end
            local flag = cfg.Flag
            local suffix = cfg.Suffix or ""
            if flag and Config:Get(flag) ~= nil then value = Config:Get(flag) end

            local card = SafeCreate("Frame", {Size=UDim2.new(1,0,0,56),
                BackgroundColor3=C("Card"), BackgroundTransparency=0.1,
                BorderSizePixel=0, Parent=Page})
            card:SetAttribute("Title", title); card:SetAttribute("Searchable", true)
            corner(card, 8); stroke(card, C("Border"), 1, 0.5)
            SafeCreate("TextLabel", {Size=UDim2.new(1,-70,0,18),
                Position=UDim2.new(0,14,0,8), BackgroundTransparency=1,
                Text=title, TextColor3=C("Text"), Font=GetFont("semibold"),
                TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, Parent=card})
            local valLbl = SafeCreate("TextLabel", {Size=UDim2.new(0,60,0,18),
                Position=UDim2.new(1,-66,0,8), BackgroundTransparency=1,
                Text=tostring(value)..suffix, TextColor3=C("Accent"),
                Font=GetFont("bold"), TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Right, Parent=card})
            local track = SafeCreate("Frame", {Size=UDim2.new(1,-28,0,5),
                Position=UDim2.new(0,14,1,-16), BackgroundColor3=C("Toggle_Off"),
                BorderSizePixel=0, Parent=card})
            corner(track, 3)
            local fill = SafeCreate("Frame", {Size=UDim2.new((value-min)/(max-min),0,1,0),
                BackgroundColor3=C("Accent"), BorderSizePixel=0, Parent=track})
            corner(fill, 3)

            local dragging = false
            local function update(input)
                local rel = math.clamp((input.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X, 0, 1)
                value = math.floor(min+(max-min)*rel+0.5)
                fill.Size = UDim2.new(rel,0,1,0)
                valLbl.Text = tostring(value)..suffix
                if flag then Config:Set(flag, value) end
                SafeCallback(cb, value)
            end
            Signals:Connect(track.InputBegan, function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true; update(input)
                end
            end)
            Signals:Connect(UserInputService.InputEnded, function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
            end)
            Signals:Connect(UserInputService.InputChanged, function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                              or input.UserInputType == Enum.UserInputType.Touch) then update(input) end
            end)
            return {
                Set=function(_,v)
                    value = math.clamp(v, min, max)
                    fill.Size = UDim2.new((value-min)/(max-min),0,1,0)
                    valLbl.Text = tostring(value)..suffix
                    SafeCallback(cb, value)
                end,
                Get=function() return value end,
            }
        end

        function Tab:AddDropdown(cfg)
            cfg = cfg or {}
            local title = cfg.Title or "Dropdown"
            local options = cfg.Options or {}
            local selected = cfg.Default or options[1] or ""
            local cb = cfg.Callback or function() end
            local flag = cfg.Flag
            local open = false
            if flag and Config:Get(flag) ~= nil then selected = Config:Get(flag) end

            local card = SafeCreate("Frame", {Size=UDim2.new(1,0,0,56),
                BackgroundColor3=C("Card"), BackgroundTransparency=0.1,
                BorderSizePixel=0, ClipsDescendants=true, Parent=Page})
            card:SetAttribute("Title", title); card:SetAttribute("Searchable", true)
            corner(card, 8); stroke(card, C("Border"), 1, 0.5)
            SafeCreate("TextLabel", {Size=UDim2.new(1,-28,0,18),
                Position=UDim2.new(0,14,0,6), BackgroundTransparency=1,
                Text=title, TextColor3=C("Text"), Font=GetFont("semibold"),
                TextSize=12, TextXAlignment=Enum.TextXAlignment.Left, Parent=card})
            local btn = SafeCreate("TextButton", {Size=UDim2.new(1,-28,0,26),
                Position=UDim2.new(0,14,0,26), BackgroundColor3=C("Background"),
                BackgroundTransparency=0.2, Text="", BorderSizePixel=0,
                AutoButtonColor=false, Parent=card})
            corner(btn, 6); padding(btn, 0, 8, 0, 10)
            local btnLbl = SafeCreate("TextLabel", {Size=UDim2.new(1,-20,1,0),
                BackgroundTransparency=1, Text=selected, TextColor3=C("Text"),
                Font=GetFont("normal"), TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Left, Parent=btn})
            local arrow = SafeCreate("TextLabel", {Size=UDim2.new(0,16,1,0),
                Position=UDim2.new(1,-16,0,0), BackgroundTransparency=1,
                Text="v", TextColor3=C("SubText"), Font=GetFont("bold"),
                TextSize=10, Parent=btn})
            local list = SafeCreate("Frame", {Size=UDim2.new(1,-28,0,0),
                Position=UDim2.new(0,14,0,54), BackgroundColor3=C("Background"),
                BackgroundTransparency=0.1, BorderSizePixel=0, Parent=card})
            corner(list, 6)
            SafeCreate("UIListLayout", {SortOrder=Enum.SortOrder.LayoutOrder, Parent=list})

            local function refresh()
                for _, c in ipairs(list:GetChildren()) do
                    if c:IsA("TextButton") then c:Destroy() end
                end
                for _, opt in ipairs(options) do
                    local item = SafeCreate("TextButton", {Size=UDim2.new(1,0,0,26),
                        BackgroundColor3=C("Background"), BackgroundTransparency=1,
                        Text="  "..tostring(opt),
                        TextColor3=opt==selected and C("Accent") or C("Text"),
                        Font=GetFont("normal"), TextSize=12,
                        TextXAlignment=Enum.TextXAlignment.Left,
                        BorderSizePixel=0, AutoButtonColor=false, Parent=list})
                    Signals:Connect(item.MouseEnter, function()
                        SafeTween(item, 0.1, {BackgroundTransparency=0.5, BackgroundColor3=C("CardHover")}) end)
                    Signals:Connect(item.MouseLeave, function()
                        SafeTween(item, 0.1, {BackgroundTransparency=1}) end)
                    Signals:Connect(item.MouseButton1Click, function()
                        selected = opt
                        btnLbl.Text = tostring(opt)
                        if flag then Config:Set(flag, opt) end
                        SafeCallback(cb, opt)
                        open = false
                        SafeTween(card, 0.2, {Size=UDim2.new(1,0,0,56)})
                        SafeTween(arrow, 0.2, {Rotation=0})
                        refresh()
                    end)
                end
            end
            Signals:Connect(btn.MouseButton1Click, function()
                open = not open
                if open then
                    refresh()
                    local h = #options * 26 + 6
                    SafeTween(card, 0.2, {Size=UDim2.new(1,0,0,56+h)})
                    SafeTween(list, 0.2, {Size=UDim2.new(1,-28,0,#options*26)})
                    SafeTween(arrow, 0.2, {Rotation=180})
                else
                    SafeTween(card, 0.2, {Size=UDim2.new(1,0,0,56)})
                    SafeTween(arrow, 0.2, {Rotation=0})
                end
            end)
            return {
                Set=function(_,v) selected=v; btnLbl.Text=tostring(v); SafeCallback(cb,v) end,
                Get=function() return selected end,
                Refresh=function(_,no) options=no; refresh() end,
            }
        end

        function Tab:AddTextbox(cfg)
            cfg = cfg or {}
            local title = cfg.Title or "Textbox"
            local placeholder = cfg.Placeholder or ""
            local default = cfg.Default or ""
            local cb = cfg.Callback or function() end
            local flag = cfg.Flag
            if flag and Config:Get(flag) ~= nil then default = Config:Get(flag) end

            local card = SafeCreate("Frame", {Size=UDim2.new(1,0,0,56),
                BackgroundColor3=C("Card"), BackgroundTransparency=0.1,
                BorderSizePixel=0, Parent=Page})
            card:SetAttribute("Title", title); card:SetAttribute("Searchable", true)
            corner(card, 8); stroke(card, C("Border"), 1, 0.5)
            SafeCreate("TextLabel", {Size=UDim2.new(1,-28,0,18),
                Position=UDim2.new(0,14,0,6), BackgroundTransparency=1,
                Text=title, TextColor3=C("Text"), Font=GetFont("semibold"),
                TextSize=12, TextXAlignment=Enum.TextXAlignment.Left, Parent=card})
            local box = SafeCreate("TextBox", {Size=UDim2.new(1,-28,0,26),
                Position=UDim2.new(0,14,0,26), BackgroundColor3=C("Background"),
                BackgroundTransparency=0.2, Text=default, PlaceholderText=placeholder,
                TextColor3=C("Text"), PlaceholderColor3=C("SubText"),
                Font=GetFont("normal"), TextSize=12, ClearTextOnFocus=false,
                BorderSizePixel=0, Parent=card})
            corner(box, 6); padding(box, 0, 8, 0, 10)
            Signals:Connect(box.FocusLost, function(enter)
                if flag then Config:Set(flag, box.Text) end
                SafeCallback(cb, box.Text, enter)
            end)
            return {Set=function(_,v) box.Text=v end, Get=function() return box.Text end}
        end

        function Tab:AddKeybind(cfg)
            cfg = cfg or {}
            local title = cfg.Title or "Keybind"
            local cb = cfg.Callback or function() end
            local flag = cfg.Flag
            local listening = false
            local currentKey = cfg.Default or Enum.KeyCode.RightShift
            if flag and Config:Get(flag) ~= nil then
                local saved = Config:Get(flag)
                local ok, kc = pcall(function() return Enum.KeyCode[saved] end)
                if ok and kc then currentKey = kc end
            end
            local card = SafeCreate("Frame", {Size=UDim2.new(1,0,0,42),
                BackgroundColor3=C("Card"), BackgroundTransparency=0.1,
                BorderSizePixel=0, Parent=Page})
            card:SetAttribute("Title", title); card:SetAttribute("Searchable", true)
            corner(card, 8); stroke(card, C("Border"), 1, 0.5)
            SafeCreate("TextLabel", {Size=UDim2.new(1,-90,1,0),
                Position=UDim2.new(0,14,0,0), BackgroundTransparency=1,
                Text=title, TextColor3=C("Text"), Font=GetFont("semibold"),
                TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, Parent=card})
            local btn = SafeCreate("TextButton", {Size=UDim2.new(0,70,0,24),
                Position=UDim2.new(1,-82,0.5,-12), BackgroundColor3=C("Background"),
                BackgroundTransparency=0.2, Text=currentKey.Name,
                TextColor3=C("Accent"), Font=GetFont("semibold"), TextSize=11,
                BorderSizePixel=0, AutoButtonColor=false, Parent=card})
            corner(btn, 6)
            Signals:Connect(btn.MouseButton1Click, function()
                listening = true; btn.Text = "..."; btn.TextColor3 = C("Notify_Warn")
            end)
            Signals:Connect(UserInputService.InputBegan, function(input, gp)
                if listening and input.UserInputType == Enum.UserInputType.Keyboard then
                    currentKey = input.KeyCode
                    btn.Text = currentKey.Name
                    btn.TextColor3 = C("Accent")
                    listening = false
                    if flag then Config:Set(flag, currentKey.Name) end
                elseif not gp and input.KeyCode == currentKey then
                    SafeCallback(cb)
                end
            end)
            return {Set=function(_,kc) currentKey=kc; btn.Text=kc.Name end,
                    Get=function() return currentKey end}
        end

        return Tab
    end

    table.insert(AtomicUI.Windows, Window)
    return Window
end

if getgenv then getgenv().AtomicUI_v2 = AtomicUI end
return AtomicUI
