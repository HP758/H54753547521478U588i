	local bg = create("Frame", { BackgroundColor3 = theme.Surface2, BackgroundTransparency = 1, Size = UDim2.fromScale(1, 1) }, button)
	addCorner(bg, 10)
	local label = create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -18, 1, 0), Position = UDim2.new(0, 12, 0, 0), Font = Enum.Font.GothamSemibold, Text = tabObj.Title or "Tab", TextSize = 15, TextColor3 = theme.SubText, TextXAlignment = Enum.TextXAlignment.Left }, button)
	button.MouseEnter:Connect(function() if tabObj._active then return end tween(bg, 0.12, { BackgroundTransparency = 0.28 }) tween(label, 0.12, { TextColor3 = theme.Text }) end)
	button.MouseLeave:Connect(function() if tabObj._active then return end tween(bg, 0.12, { BackgroundTransparency = 1 }) tween(label, 0.12, { TextColor3 = theme.SubText }) end)
	button.MouseButton1Click:Connect(function() for _, t in ipairs(self._tabs) do t:_setActive(false) end tabObj:_setActive(true) end)
