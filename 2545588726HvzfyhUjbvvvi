-- ===== Signal 管理器 =====
local SignalManager = {}
SignalManager.__index = SignalManager
function SignalManager.new() return setmetatable({_signals={}}, SignalManager) end
function SignalManager:Connect(sig, fn)
    if not sig or not sig.Connect then return end
    local ok, c = pcall(function() return sig:Connect(fn) end)
    if ok and c then table.insert(self._signals, c); return c end
end
function SignalManager:DisconnectAll()
    for _, c in ipairs(self._signals) do pcall(function() c:Disconnect() end) end
    self._signals = {}
end

-- ===== 配置保存 =====
local ConfigSystem = {}
ConfigSystem.__index = ConfigSystem
function ConfigSystem.new(folder, name)
    local self = setmetatable({}, ConfigSystem)
    self.Folder = folder or "AtomicUI"
    self.Name = name or "config"
    self.Data = {}
    self.Path = self.Folder .. "/" .. self.Name .. ".json"
    pcall(function()
        if makefolder and not isfolder(self.Folder) then makefolder(self.Folder) end
    end)
    return self
end
function ConfigSystem:Save()
    if not HttpService or not writefile then return false end
    local ok, enc = pcall(function() return HttpService:JSONEncode(self.Data) end)
    if not ok then return false end
    return pcall(function() writefile(self.Path, enc) end)
end
function ConfigSystem:Load()
    if not HttpService or not readfile or not isfile then return false end
    if not isfile(self.Path) then return false end
    local ok, raw = pcall(function() return readfile(self.Path) end)
    if not ok then return false end
    local ok2, dec = pcall(function() return HttpService:JSONDecode(raw) end)
    if ok2 and type(dec) == "table" then self.Data = dec; return true end
    return false
end
function ConfigSystem:Set(k, v) self.Data[k] = v; self:Save() end
function ConfigSystem:Get(k, d) local v = self.Data[k]; if v == nil then return d end; return v end

local function GetAvatar(uid)
    if not Players or not uid then return "rbxasset://textures/ui/GuiImagePlaceholder.png" end
    local ok, url = pcall(function()
        return Players:GetUserThumbnailAsync(uid,
            Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
    end)
    return ok and url or "rbxasset://textures/ui/GuiImagePlaceholder.png"
end

local function MakeDraggable(frame, handle, signals)
    handle = handle or frame
    local dragging, dragStart, startPos = false
    signals:Connect(handle.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = frame.Position
        end
    end)
    signals:Connect(handle.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
    signals:Connect(UserInputService.InputChanged, function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                      or input.UserInputType == Enum.UserInputType.Touch) then
            local d = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X,
                                       startPos.Y.Scale, startPos.Y.Offset+d.Y)
        end
    end)
end

-- ===== 通知系统 =====
local NotifyContainer
local function EnsureNotifyContainer(sg)
    if NotifyContainer and NotifyContainer.Parent then return NotifyContainer end
    NotifyContainer = SafeCreate("Frame", {
        Name="NotifyContainer", Size=UDim2.new(0,280,1,-20),
        Position=UDim2.new(1,-290,0,10), BackgroundTransparency=1, Parent=sg})
    SafeCreate("UIListLayout", {SortOrder=Enum.SortOrder.LayoutOrder,
        VerticalAlignment=Enum.VerticalAlignment.Bottom,
        HorizontalAlignment=Enum.HorizontalAlignment.Right,
        Padding=UDim.new(0,8), Parent=NotifyContainer})
    return NotifyContainer
end

local function FadeAll(parent, time)
    for _, v in ipairs(parent:GetDescendants()) do
        if v:IsA("Frame") then SafeTween(v, time, {BackgroundTransparency=1})
        elseif v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
            SafeTween(v, time, {TextTransparency=1, BackgroundTransparency=1})
        elseif v:IsA("ImageLabel") or v:IsA("ImageButton") then
            SafeTween(v, time, {ImageTransparency=1, BackgroundTransparency=1})
        elseif v:IsA("UIStroke") then SafeTween(v, time, {Transparency=1}) end
    end
    if parent:IsA("Frame") then SafeTween(parent, time, {BackgroundTransparency=1}) end
end

local function Notify(sg, title, msg, duration, kind)
    duration = duration or 3
    local accent = kind=="warn" and C("Notify_Warn")
                or kind=="err"  and C("Notify_Err") or C("Notify_OK")
    EnsureNotifyContainer(sg)
    local n = SafeCreate("Frame", {Size=UDim2.new(0,270,0,64),
        BackgroundColor3=C("Card"), BorderSizePixel=0,
        BackgroundTransparency=1, Parent=NotifyContainer})
    corner(n, 8); stroke(n, accent, 1, 0.5)
    local bar = SafeCreate("Frame", {Size=UDim2.new(0,3,1,-16),
        Position=UDim2.new(0,8,0,8), BackgroundColor3=accent,
        BorderSizePixel=0, BackgroundTransparency=1, Parent=n})
    corner(bar, 2)
    local tL = SafeCreate("TextLabel", {Size=UDim2.new(1,-28,0,20),
        Position=UDim2.new(0,18,0,10), BackgroundTransparency=1, Text=title or "",
        TextColor3=C("Text"), TextTransparency=1, Font=GetFont("bold"),
        TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, Parent=n})
    local mL = SafeCreate("TextLabel", {Size=UDim2.new(1,-28,0,30),
        Position=UDim2.new(0,18,0,28), BackgroundTransparency=1, Text=msg or "",
        TextColor3=C("SubText"), TextTransparency=1, Font=GetFont("normal"),
        TextSize=11, TextXAlignment=Enum.TextXAlignment.Left,
        TextYAlignment=Enum.TextYAlignment.Top, TextWrapped=true, Parent=n})
    SafeTween(n, 0.25, {BackgroundTransparency=0})
    SafeTween(bar, 0.25, {BackgroundTransparency=0})
    SafeTween(tL, 0.25, {TextTransparency=0})
    SafeTween(mL, 0.25, {TextTransparency=0})
    task.delay(duration, function()
        FadeAll(n, 0.3); task.wait(0.35); pcall(function() n:Destroy() end)
    end)
end
