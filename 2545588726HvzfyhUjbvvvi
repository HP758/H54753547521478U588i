local LocalPlayer = Players and Players.LocalPlayer
if Players and not LocalPlayer then
    local s = tick()
    repeat task.wait() until Players.LocalPlayer or (tick() - s) > 10
    LocalPlayer = Players.LocalPlayer
end

local function SafeCreate(class, props)
    local ok, inst = pcall(Instance.new, class)
    if not ok or not inst then return nil end
    if props then
        for k, v in pairs(props) do
            if k ~= "Parent" then pcall(function() inst[k] = v end) end
        end
        if props.Parent then pcall(function() inst.Parent = props.Parent end) end
    end
    return inst
end

local function SafeTween(obj, time, props, style, dir)
    if not obj or not TweenService then return end
    local ok, tw = pcall(function()
        return TweenService:Create(obj,
            TweenInfo.new(time or 0.2,
                style or Enum.EasingStyle.Quad,
                dir   or Enum.EasingDirection.Out), props)
    end)
    if ok and tw then pcall(function() tw:Play() end); return tw end
end

local function SafeCallback(fn, ...)
    if not fn or type(fn) ~= "function" then return end
    local ok, err = pcall(fn, ...)
    if not ok then warn("[AtomicUI] Callback Error:", err) end
end

local function GetFont(w)
    local map = {bold=Enum.Font.GothamBold, semibold=Enum.Font.GothamSemibold,
                 medium=Enum.Font.GothamMedium, normal=Enum.Font.Gotham}
    return map[w] or Enum.Font.SourceSans
end

