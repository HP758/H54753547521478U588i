		sectionOpts = sectionOpts or {}
		local sec = setmetatable({ _tab = self, _window = self._window, Title = sectionOpts.Title or "Section" }, Section)
		table.insert(self._sections, sec)
		local card = create("Frame", { BackgroundColor3 = getTheme(self._window).Background, BackgroundTransparency = 0.08, Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y }, self._page)
		addCorner(card, 16); addStroke(card, Color3.fromRGB(255, 255, 255), 0.9, 1)
		create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 12), Size = UDim2.new(1, -28, 0, 20), Font = Enum.Font.GothamSemibold, Text = sec.Title, TextSize = 16, TextColor3 = getTheme(self._window).Text, TextXAlignment = Enum.TextXAlignment.Left }, card)
		local body = create("Frame", { BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0, 40), Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y }, card)
		create("UIPadding", { PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12), PaddingBottom = UDim.new(0, 12), Parent = body })
		create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 8), Parent = body })
		sec._card = card; sec._body = body
		function sec:Button(data) return self:_button(data) end
		function sec:Toggle(data) return self:_toggle(data) end
		function sec:Input(data) return self:_input(data) end
		function sec:Slider(data) return self:_slider(data) end
		function sec:Dropdown(data) return self:_dropdown(data) end
		return sec
	end
	if #self._tabs == 1 then tab:_setActive(true) end
	return tab
end

function Section:_componentCard(height)
	local card = create("Frame", { BackgroundColor3 = getTheme(self._window).Surface2, BackgroundTransparency = 0.05, Size = UDim2.new(1, 0, 0, height or 44) }, self._body)
	addCorner(card, 12); addStroke(card, Color3.fromRGB(255, 255, 255), 0.94, 1)
	return card
end

function Section:_button(data)
	data = data or {}
	local card = self:_componentCard(44)
	local button = create("TextButton", { BackgroundTransparency = 1, Size = UDim2.fromScale(1, 1), Text = "", AutoButtonColor = false }, card)
	create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 0), Size = UDim2.new(1, -28, 1, 0), Font = Enum.Font.GothamSemibold, Text = tostring(data.Title or "Button"), TextSize = 15, TextColor3 = getTheme(self._window).Text, TextXAlignment = Enum.TextXAlignment.Left }, button)
	button.MouseEnter:Connect(function() tween(card, 0.12, { BackgroundTransparency = 0.0 }) end)
	button.MouseLeave:Connect(function() tween(card, 0.12, { BackgroundTransparency = 0.05 }) end)
	button.MouseButton1Click:Connect(function() safeCall(data.Callback or function() end) end)
	return { Instance = card, Button = button }
end

function Section:_toggle(data)
	data = data or {}
	local card = self:_componentCard(44)
	create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 0), Size = UDim2.new(1, -72, 1, 0), Font = Enum.Font.GothamSemibold, Text = tostring(data.Title or "Toggle"), TextSize = 15, TextColor3 = getTheme(self._window).Text, TextXAlignment = Enum.TextXAlignment.Left }, card)
	local switch = create("Frame", { BackgroundColor3 = Color3.fromRGB(80, 80, 92), AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -14, 0.5, 0), Size = UDim2.fromOffset(48, 24) }, card)
	addCorner(switch, 999)
	local knob = create("Frame", { BackgroundColor3 = Color3.fromRGB(255, 255, 255), AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 3, 0.5, 0), Size = UDim2.fromOffset(18, 18) }, switch)
	addCorner(knob, 999)
	local value = data.Default == true
	local function render()
		local theme = getTheme(self._window)
		if value then switch.BackgroundColor3 = theme.Accent; knob.Position = UDim2.new(1, -21, 0.5, 0) else switch.BackgroundColor3 = Color3.fromRGB(80, 80, 92); knob.Position = UDim2.new(0, 3, 0.5, 0) end
	end
	render()
	card.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			value = not value; render(); safeCall(data.Callback or function() end, value)
		end
	end)
	return { Instance = card, Set = function(_, v) value = v == true; render() end, Get = function() return value end }
end

function Section:_input(data)
	data = data or {}
	local card = self:_componentCard(48)
	create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 0), Size = UDim2.new(0.42, -14, 1, 0), Font = Enum.Font.GothamSemibold, Text = tostring(data.Title or "Input"), TextSize = 15, TextColor3 = getTheme(self._window).Text, TextXAlignment = Enum.TextXAlignment.Left }, card)
	local box = create("TextBox", { BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 0.92, AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -14, 0.5, 0), Size = UDim2.new(0.55, 0, 0, 30), ClearTextOnFocus = false, Text = tostring(data.Default or ""), PlaceholderText = tostring(data.Placeholder or "Enter text"), Font = Enum.Font.Gotham, TextSize = 14, TextColor3 = getTheme(self._window).Text }, card)
	addCorner(box, 10); addStroke(box, Color3.fromRGB(255, 255, 255), 0.95, 1)
	box.FocusLost:Connect(function() safeCall(data.Callback or function() end, box.Text) end)
	return { Instance = card, Box = box }
end

function Section:_slider(data)
	data = data or {}
	local min = tonumber(data.Min) or 0
	local max = tonumber(data.Max) or 100
	local value = math.clamp(tonumber(data.Default) or min, min, max)
	local card = self:_componentCard(62)
	create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 8), Size = UDim2.new(1, -28, 0, 20), Font = Enum.Font.GothamSemibold, Text = tostring(data.Title or "Slider"), TextSize = 15, TextColor3 = getTheme(self._window).Text, TextXAlignment = Enum.TextXAlignment.Left }, card)
	local valText = create("TextLabel", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1, 0), Position = UDim2.new(1, -14, 0, 8), Size = UDim2.fromOffset(120, 20), Font = Enum.Font.Gotham, Text = tostring(value), TextSize = 14, TextColor3 = getTheme(self._window).SubText, TextXAlignment = Enum.TextXAlignment.Right }, card)
	local bar = create("Frame", { BackgroundColor3 = Color3.fromRGB(70, 70, 80), BackgroundTransparency = 0.25, Position = UDim2.new(0, 14, 0, 38), Size = UDim2.new(1, -28, 0, 10) }, card)
	addCorner(bar, 999)
	local fill = create("Frame", { BackgroundColor3 = getTheme(self._window).Accent, BackgroundTransparency = 0, Size = UDim2.new(0, 0, 1, 0) }, bar)
	addCorner(fill, 999)
	local dragging = false
	local function render()
		local alpha = (value - min) / math.max(1e-6, (max - min))
		fill.Size = UDim2.new(alpha, 0, 1, 0)
		valText.Text = tostring(math.floor(value * 1000 + 0.5) / 1000)
	end
	render()
	local function setFromX(x)
		local abs = bar.AbsolutePosition.X
		local width = math.max(1, bar.AbsoluteSize.X)
		local alpha = math.clamp((x - abs) / width, 0, 1)
		value = min + (max - min) * alpha
		render(); safeCall(data.Callback or function() end, value)
	end
	bar.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true; setFromX(input.Position.X) end end)
	bar.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
	card.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true; setFromX(input.Position.X) end end)
	local rsConn = RunService.RenderStepped:Connect(function() if dragging then local mouse = game:GetService("UserInputService"):GetMouseLocation(); setFromX(mouse.X) end end)
	self._window._disposable:Add(rsConn)
	return { Instance = card, Set = function(_, v) value = math.clamp(tonumber(v) or value, min, max); render() end, Get = function() return value end }
end

function Section:_dropdown(data)
	data = data or {}
	local values = data.Values or {}
	local open = false
	local selected = data.Default or values[1]
	local card = self:_componentCard(44)
	local label = create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 0), Size = UDim2.new(1, -42, 1, 0), Font = Enum.Font.GothamSemibold, Text = tostring(data.Title or "Dropdown"), TextSize = 15, TextColor3 = getTheme(self._window).Text, TextXAlignment = Enum.TextXAlignment.Left }, card)
	local arrow = create("TextLabel", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -14, 0.5, 0), Size = UDim2.fromOffset(16, 16), Font = Enum.Font.GothamBold, Text = "⌄", TextSize = 18, TextColor3 = getTheme(self._window).SubText }, card)
	local list = create("Frame", { BackgroundColor3 = getTheme(self._window).Background, BackgroundTransparency = 0.02, Visible = false, Position = UDim2.new(0, 0, 1, 6), Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, ZIndex = 10 }, card)
	addCorner(list, 12); addStroke(list, Color3.fromRGB(255, 255, 255), 0.94, 1)
	create("UIPadding", { PaddingTop = UDim.new(0, 6), PaddingBottom = UDim.new(0, 6), PaddingLeft = UDim.new(0, 6), PaddingRight = UDim.new(0, 6), Parent = list })
	create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 4), Parent = list })
	local header = create("TextLabel", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -38, 0.5, 0), Size = UDim2.new(0, 180, 1, 0), Font = Enum.Font.Gotham, Text = tostring(selected or "Select"), TextSize = 14, TextColor3 = getTheme(self._window).SubText, TextXAlignment = Enum.TextXAlignment.Right }, card)
	local function refreshHeader() header.Text = tostring(selected or "Select"); arrow.Text = open and "⌃" or "⌄" end
	local function closeList() open = false; list.Visible = false; card.Size = UDim2.new(1, 0, 0, 44); refreshHeader() end
	local function openList() open = true; list.Visible = true; card.Size = UDim2.new(1, 0, 0, 44); refreshHeader() end
	local function buildItems()
		for _, child in ipairs(list:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
		for _, v in ipairs(values) do
			local b = create("TextButton", { BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 0.93, Size = UDim2.new(1, 0, 0, 32), Text = tostring(v), AutoButtonColor = false, Font = Enum.Font.Gotham, TextSize = 14, TextColor3 = getTheme(self._window).Text }, list)
			addCorner(b, 10)
			b.MouseButton1Click:Connect(function() selected = v; refreshHeader(); closeList(); safeCall(data.Callback or function() end, selected) end)
		end
	end
	buildItems()
	card.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then if open then closeList() else openList() end end end)
	return { Instance = card, Set = function(_, v) selected = v; refreshHeader() end, Get = function() return selected end }
end

function WindUI:CreateWindow(opts)
	opts = opts or {}
	local window = setmetatable({ _opts = opts, _tabs = {}, _themeObjects = {}, _disposable = Disposable.new(), _screenGui = nil, _main = nil, _topbar = nil, _sidebar = nil, _sidebarList = nil, _content = nil, _pageHolder = nil, _divider = nil, _title = nil, _author = nil, _theme = nil, _background = nil, _notifications = nil, _bgConfig = nil, _transparent = opts.Transparent ~= false }, Window)
	local guiParent = getParentGui(); assert(guiParent, "WindUI: No valid GUI parent found.")
	local screenGui = create("ScreenGui", { Name = "WindUI_Window", ResetOnSpawn = false, ZIndexBehavior = Enum.ZIndexBehavior.Sibling }, guiParent)
	window._screenGui = screenGui; window._disposable:Add(screenGui)
	local size = opts.Size or UDim2.fromOffset(920, 600)
	local main = create("Frame", { Name = "Main", AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.fromScale(0.5, 0.5), Size = size, BackgroundColor3 = Color3.fromRGB(26, 26, 32), BackgroundTransparency = window._transparent and 0.08 or 0, ClipsDescendants = true }, screenGui)
	window._main = main; window._disposable:Add(main); addCorner(main, 18); addStroke(main, Color3.fromRGB(255, 255, 255), 0.92, 1)
	local topbar = create("Frame", { Name = "Topbar", BackgroundColor3 = Color3.fromRGB(18, 18, 22), BackgroundTransparency = 0.1, Size = UDim2.new(1, 0, 0, 58) }, main)
	window._topbar = topbar; addCorner(topbar, 18)
	local title = create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 18, 0, 10), Size = UDim2.new(1, -120, 0, 24), Font = Enum.Font.GothamSemibold, Text = tostring(opts.Title or "WindUI Next"), TextSize = 20, TextColor3 = Color3.fromRGB(255, 255, 255), TextXAlignment = Enum.TextXAlignment.Left }, topbar)
	window._title = title
	local author = create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 18, 0, 32), Size = UDim2.new(1, -120, 0, 18), Font = Enum.Font.Gotham, Text = tostring(opts.Author or "Framework"), TextSize = 13, TextColor3 = Color3.fromRGB(180, 180, 190), TextXAlignment = Enum.TextXAlignment.Left }, topbar)
	window._author = author
	local sidebar = create("Frame", { Name = "Sidebar", BackgroundColor3 = Color3.fromRGB(18, 18, 22), BackgroundTransparency = 0.1, Position = UDim2.new(0, 0, 0, 58), Size = UDim2.new(0, 210, 1, -58) }, main)
	window._sidebar = sidebar
	local sidebarList = create("ScrollingFrame", { BackgroundTransparency = 1, Position = UDim2.fromScale(0, 0), Size = UDim2.fromScale(1, 1), CanvasSize = UDim2.new(0, 0, 0, 0), AutomaticCanvasSize = Enum.AutomaticSize.Y, ScrollBarThickness = 3, ScrollBarImageTransparency = 0.5 }, sidebar)
	window._sidebarList = sidebarList
	create("UIPadding", { PaddingTop = UDim.new(0, 12), PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10), PaddingBottom = UDim.new(0, 12), Parent = sidebarList })
	create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 8), Parent = sidebarList })
	local divider = create("Frame", { BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 0.92, Position = UDim2.new(0, 210, 0, 58), Size = UDim2.new(0, 1, 1, -58) }, main)
	window._divider = divider
	local content = create("Frame", { Name = "Content", BackgroundColor3 = Color3.fromRGB(26, 26, 32), BackgroundTransparency = 0.06, Position = UDim2.new(0, 211, 0, 58), Size = UDim2.new(1, -211, 1, -58) }, main)
	window._content = content
	local pageHolder = create("Frame", { BackgroundTransparency = 1, Position = UDim2.fromScale(0, 0), Size = UDim2.fromScale(1, 1) }, content)
	window._pageHolder = pageHolder
	window._theme = ThemeService.new(window)
	window._background = BackgroundService.new(window, opts.Background or { Enabled = false })
	window._notifications = NotificationService.new(window)
	window._disposable:Add(window._theme)
	window._disposable:Add(window._background)
	window._disposable:Add(window._notifications)
	if opts.Background and opts.Background.Enabled ~= false then window:SetBackground(opts.Background) end
	window:_applyBaseTheme()
	local dragging, dragStart, startPos = false, nil, nil
	window._disposable:Add(topbar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true; dragStart = input.Position; startPos = main.Position end
	end))
	window._disposable:Add(topbar.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end))
	window._disposable:Add(topbar.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
	end))
	if (opts.Boot and opts.Boot.Enabled ~= false) or (opts.Boot == nil and WindUI.Config.EnableBoot) then
		local bootTitle = (opts.Boot and (opts.Boot.Title or opts.Title)) or opts.Title or WindUI.Config.BootTitle
		local bootSub = (opts.Boot and opts.Boot.Subtitle) or WindUI.Config.BootSubtitle
		local bootDur = (opts.Boot and opts.Boot.Duration) or WindUI.Config.BootDuration
		playBoot(bootTitle, bootSub, bootDur)
	end
	function window:Theme() return self._theme end
	function window:Notify(data) return self._notifications:Notify(data) end
	function window:SetLanguage(_) return true end
	function window:SetFont(_) return true end
	function window:AddTheme(object, properties) registerThemeObject(self, object, properties); self._theme:Apply(); return object end
	function window:Destroy() if self._disposable then self._disposable:Destroy() end if self._screenGui and self._screenGui.Parent then self._screenGui:Destroy() end end
	function window:SetTheme(name) if self._theme then return self._theme:SetTheme(name) end return false end
	function window:GetTheme() if self._theme then return self._theme:GetTheme() end return WindUI.Config.Theme end
	function window:SetBackground(config) self._bgConfig = config or {}; if self._background then self._background:Set(self._bgConfig) end end
	function window:Tab(tabOpts)
		return Window.Tab(self, tabOpts)
	end
	return window
end

function WindUI:SetTheme(name) self.Config.Theme = name or self.Config.Theme end
function WindUI:Notify(data)
	local guiParent = getParentGui(); if not guiParent then return nil end
	local temp = create("ScreenGui", { Name = "WindUI_Notify_Standalone", ResetOnSpawn = false, ZIndexBehavior = Enum.ZIndexBehavior.Sibling }, guiParent)
	local holder = create("Frame", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1, 1), Position = UDim2.new(1, -18, 1, -18), Size = UDim2.fromOffset(300, 80) }, temp)
	local box = create("Frame", { BackgroundColor3 = Color3.fromRGB(26, 26, 32), BackgroundTransparency = 0.1, Size = UDim2.fromScale(1, 1) }, holder)
	addCorner(box, 14); addStroke(box, Color3.fromRGB(255,255,255), 0.92, 1)
	create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 10), Size = UDim2.new(1, -28, 0, 20), Font = Enum.Font.GothamSemibold, Text = tostring(data and data.Title or "Notification"), TextSize = 15, TextColor3 = Color3.fromRGB(255,255,255), TextXAlignment = Enum.TextXAlignment.Left }, box)
	create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 34), Size = UDim2.new(1, -28, 0, 18), Font = Enum.Font.Gotham, Text = tostring(data and data.Content or ""), TextSize = 13, TextColor3 = Color3.fromRGB(210,210,220), TextXAlignment = Enum.TextXAlignment.Left }, box)
	task.spawn(function() task.wait(tonumber(data and data.Duration) or 3); if temp and temp.Parent then temp:Destroy() end end)
	return temp
end
function WindUI:SetBackground(config) self._pendingBackground = config end

return WindUI
