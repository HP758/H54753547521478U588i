local function playBoot(title, subtitle, duration)
	local guiParent = getParentGui()
	if not guiParent then return nil end
	local gui = create("ScreenGui", { Name = "WindUI_Boot", ResetOnSpawn = false, ZIndexBehavior = Enum.ZIndexBehavior.Sibling }, guiParent)
	local overlay = create("Frame", { BackgroundColor3 = Color3.new(0, 0, 0), BackgroundTransparency = 0.45, Size = UDim2.fromScale(1, 1) }, gui)
	local center = create("Frame", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.fromScale(0.5, 0.45), Size = UDim2.fromOffset(420, 120) }, gui)
	local name = create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 60), Font = Enum.Font.GothamSemibold, Text = tostring(title or "WindUI Next"), TextSize = 34, TextColor3 = Color3.fromRGB(255, 255, 255), TextTransparency = 1 }, center)
	local sub = create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0, 52), Size = UDim2.new(1, 0, 0, 32), Font = Enum.Font.Gotham, Text = tostring(subtitle or "Starting..."), TextSize = 16, TextColor3 = Color3.fromRGB(210, 210, 220), TextTransparency = 1 }, center)
	addCorner(center, 18)
	local toast = create("Frame", { BackgroundColor3 = Color3.fromRGB(24, 24, 28), BackgroundTransparency = 0.08, AnchorPoint = Vector2.new(1, 1), Position = UDim2.new(1, -18, 1, -18), Size = UDim2.fromOffset(240, 70) }, gui)
	addCorner(toast, 14); addStroke(toast, Color3.fromRGB(255, 255, 255), 0.92, 1)
	local toastTitle = create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 10), Size = UDim2.new(1, -28, 0, 22), Font = Enum.Font.GothamSemibold, Text = tostring(title or "WindUI Next"), TextSize = 16, TextColor3 = Color3.fromRGB(255, 255, 255), TextTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left }, toast)
	local toastSub = create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 34), Size = UDim2.new(1, -28, 0, 18), Font = Enum.Font.Gotham, Text = "Script loaded successfully", TextSize = 13, TextColor3 = Color3.fromRGB(200, 200, 210), TextTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left }, toast)
	task.spawn(function()
		tween(name, 0.16, { TextTransparency = 0 })
		tween(sub, 0.18, { TextTransparency = 0.12 })
		tween(toastTitle, 0.18, { TextTransparency = 0 })
		tween(toastSub, 0.18, { TextTransparency = 0 })
		task.wait(math.max(0.18, duration * 0.55))
		tween(name, 0.18, { TextTransparency = 1 })
		tween(sub, 0.18, { TextTransparency = 1 })
		tween(toastTitle, 0.18, { TextTransparency = 1 })
		tween(toastSub, 0.18, { TextTransparency = 1 })
		tween(overlay, 0.18, { BackgroundTransparency = 1 })
		tween(toast, 0.18, { BackgroundTransparency = 1 })
		task.wait(0.2)
		if gui then gui:Destroy() end
	end)
	return gui
end

local ThemeService = {}; ThemeService.__index = ThemeService
function ThemeService.new(window)
	return setmetatable({ _window = window, _name = WindUI.Config.Theme or "Dark", _current = WindUI.Themes[WindUI.Config.Theme] or WindUI.Themes.Dark, _subscribers = {} }, ThemeService)
end
function ThemeService:GetTheme() return self._name, self._current end
function ThemeService:SetTheme(name)
	local theme = WindUI.Themes[name]; if not theme then return false end
	local prev = self._name; self._name = name; self._current = theme
	WindUI.EventBus:Fire("ThemeChanged", name, prev, theme)
	self:Apply(); return true
end
function ThemeService:GetColor(key) return self._current[key] end
function ThemeService:Subscribe(callback)
	if typeof(callback) ~= "function" then return { Disconnect = function() end } end
	table.insert(self._subscribers, callback)
	local alive = true
	return { Disconnect = function() if not alive then return end; alive = false; for i = #self._subscribers, 1, -1 do if self._subscribers[i] == callback then table.remove(self._subscribers, i); break end end end }
end
function ThemeService:Apply()
	local t = self._current; if not t then return end
	if self._window and self._window._themeObjects then
		for _, item in ipairs(self._window._themeObjects) do
			local obj = item.Object
			if obj and obj.Parent then
				for prop, source in pairs(item.Properties) do
					local value = t[source] ~= nil and t[source] or source
					if typeof(value) == "Color3" or typeof(value) == "number" then obj[prop] = value end
				end
			end
		end
	end
	for _, cb in ipairs(self._subscribers) do task.spawn(function() safeCall(cb, self._name, t) end) end
end
function ThemeService:Destroy()
	table.clear(self._subscribers)
end

local BackgroundService = {}; BackgroundService.__index = BackgroundService
function BackgroundService.new(window, config)
	return setmetatable({ _window = window, _config = config or {}, _root = nil, _layers = {}, _connections = {}, _motionRunning = false }, BackgroundService)
end
function BackgroundService:_clear()
	for _, c in ipairs(self._connections) do pcall(function() c:Disconnect() end) end
	table.clear(self._connections)
	for _, layer in ipairs(self._layers) do if layer and layer.Parent then layer:Destroy() end end
	table.clear(self._layers)
	if self._root then pcall(function() self._root:Destroy() end) self._root = nil end
	self._motionRunning = false
end
function BackgroundService:Set(config)
	self:_clear(); self._config = config or {}
	local main = self._window and self._window._main; if not main then return end
	if self._config.Enabled == false then return end
	local container = create("Frame", { Name = "BackgroundLayer", BackgroundTransparency = 1, Size = UDim2.fromScale(1, 1), ClipsDescendants = true, ZIndex = 0 }, main)
	self._root = container
	local imageList = self._config.Images
	local baseImage = nil
	if imageList and type(imageList) == "table" and #imageList > 0 then baseImage = resolveAsset(imageList[1]) else baseImage = resolveAsset(self._config.Image) end
	local bg = create("ImageLabel", { Name = "BackgroundImage", BackgroundTransparency = 1, Size = UDim2.fromScale(1, 1), Image = baseImage or "", ImageTransparency = self._config.Transparency or 0.12, ScaleType = Enum.ScaleType.Crop, ZIndex = 0 }, container)
	table.insert(self._layers, bg)
	local overlay = create("Frame", { Name = "BackgroundOverlay", BackgroundColor3 = Color3.new(0, 0, 0), BackgroundTransparency = self._config.OverlayTransparency or 0.88, Size = UDim2.fromScale(1, 1), ZIndex = 1 }, container)
	table.insert(self._layers, overlay)
	if self._config.Motion ~= false and WindUI.Config.EnableBackgroundMotion then
		local amp = tonumber(self._config.MotionAmplitude) or WindUI.Config.BackgroundMotionAmplitude
		local spd = tonumber(self._config.MotionSpeed) or WindUI.Config.BackgroundMotionSpeed
		local t0 = os.clock(); self._motionRunning = true
		local conn; conn = RunService.Heartbeat:Connect(function()
			if not self._motionRunning or not bg.Parent then if conn then conn:Disconnect() end return end
			local dt = os.clock() - t0
			bg.Position = UDim2.new(0, math.sin(dt * (spd * 4)) * amp, 0, math.cos(dt * (spd * 3.3)) * (amp * 0.55))
			bg.Rotation = math.sin(dt * (spd * 1.3)) * 0.35
		end)
		table.insert(self._connections, conn)
	end
end
function BackgroundService:Destroy() self:_clear() end

local NotificationService = {}; NotificationService.__index = NotificationService
function NotificationService.new(window)
	return setmetatable({ _window = window, _holder = nil, _notifications = {} }, NotificationService)
end
function NotificationService:_ensureHolder()
	if self._holder and self._holder.Parent then return self._holder end
	local holder = create("Frame", { Name = "NotificationHolder", BackgroundTransparency = 1, AnchorPoint = Vector2.new(1, 1), Position = UDim2.new(1, -18, 1, -18), Size = UDim2.fromOffset(320, 500) }, self._window._screenGui)
	create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, HorizontalAlignment = Enum.HorizontalAlignment.Right, VerticalAlignment = Enum.VerticalAlignment.Bottom, Padding = UDim.new(0, 8), Parent = holder })
	self._holder = holder; return holder
end
function NotificationService:Notify(data)
	data = data or {}
	local holder = self:_ensureHolder()
	local frame = create("Frame", { BackgroundColor3 = Color3.fromRGB(26, 26, 32), BackgroundTransparency = 0.08, Size = UDim2.fromOffset(280, 72) }, holder)
	addCorner(frame, 14); addStroke(frame, Color3.fromRGB(255, 255, 255), 0.9, 1)
	create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 10), Size = UDim2.new(1, -28, 0, 20), Font = Enum.Font.GothamSemibold, Text = tostring(data.Title or "Notification"), TextSize = 15, TextColor3 = Color3.fromRGB(255, 255, 255), TextXAlignment = Enum.TextXAlignment.Left }, frame)
	create("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 32), Size = UDim2.new(1, -28, 0, 18), Font = Enum.Font.Gotham, Text = tostring(data.Content or ""), TextSize = 13, TextColor3 = Color3.fromRGB(205, 205, 214), TextXAlignment = Enum.TextXAlignment.Left }, frame)
	frame.Position = UDim2.new(1, 360, 1, -18)
	tween(frame, 0.22, { Position = UDim2.new(1, -18, 1, -18) })
	local duration = tonumber(data.Duration) or 3
	task.spawn(function()
		task.wait(duration)
		tween(frame, 0.18, { Position = UDim2.new(1, 360, 1, -18), BackgroundTransparency = 1 })
		task.wait(0.2)
		if frame and frame.Parent then frame:Destroy() end
	end)
	table.insert(self._notifications, frame)
	return frame
end
function NotificationService:Destroy()
	for _, n in ipairs(self._notifications) do
		if n and n.Parent then pcall(function() n:Destroy() end) end
	end
	table.clear(self._notifications)
	if self._holder and self._holder.Parent then pcall(function() self._holder:Destroy() end) end
	self._holder = nil
end

local Window = {}; Window.__index = Window
local Tab = {}; Tab.__index = Tab
local Section = {}; Section.__index = Section

local function getTheme(window)
	return (window and window._theme and window._theme._current) or WindUI.Themes[WindUI.Config.Theme] or WindUI.Themes.Dark
end

local function registerThemeObject(window, object, properties)
	window._themeObjects = window._themeObjects or {}
	table.insert(window._themeObjects, { Object = object, Properties = properties or {} })
end

function Window:_applyBaseTheme()
	local theme = getTheme(self); if not theme then return end
	self._main.BackgroundColor3 = theme.Surface
	self._main.BackgroundTransparency = self._transparent and 0.08 or 0
	self._topbar.BackgroundColor3 = theme.Background
	self._sidebar.BackgroundColor3 = theme.Background
	self._content.BackgroundColor3 = theme.Surface
	self._divider.BackgroundColor3 = theme.Stroke
	self._divider.BackgroundTransparency = theme.StrokeTransparency
